# ── Docker Desktop : copier vers docker/.env ──
#    cp docker/.env.example docker/.env
#
# APP_KEY : depuis la racine du repo (PHP installé) :
#   cd Backend && php artisan key:generate --show
# Ou une fois le stack up :
#   docker compose --env-file docker/.env exec app php artisan key:generate --show
# Puis coller la valeur ici et redémarrer : docker compose --env-file docker/.env up -d

APP_KEY=
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:8080

# Port publié sur la machine hôte (évite le 80 souvent pris sous Windows)
APP_PORT=8080
APP_BIND=127.0.0.1

# Exposer Postgres sur l’hôte (DBeaver, etc.) — 5433 évite conflit avec un Postgres local
POSTGRES_PORT=5433
POSTGRES_BIND=127.0.0.1

DB_DATABASE=bfatlm
DB_USERNAME=bfatlm
DB_PASSWORD=bfatlm_local_change_me

REDIS_PASSWORD=

# Reverb / file d’attente (optionnel en local)
ENABLE_REVERB=false
ENABLE_QUEUE=false
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Premier démarrage : seed production + comptes par rôle (même mot de passe pour les comptes métier)
# RUN_SEED=true
# SEED_DEMO_DATA=false
# SEED_ROLE_ACCOUNTS=true
# INITIAL_ADMIN_PASSWORD=ChangeMoi12CharsMin
# INITIAL_ROLE_ACCOUNTS_PASSWORD=ChangeMoi12CharsMin

SESSION_SECURE_COOKIE=false
