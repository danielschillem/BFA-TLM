# https://editorconfig.org — racine du dépôt BFA TLM
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{js,jsx,mjs,cjs,ts,tsx,json,css}]
indent_size = 2

[*.php]
indent_size = 4

[Makefile]
indent_style = tab
