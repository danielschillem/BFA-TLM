############################################################
# BFA TLM — Variables d'environnement DigitalOcean
# Copier en .env dans le dossier digitalocean/ puis remplir
############################################################

# ── Application ──
APP_KEY=                              # php artisan key:generate --show
APP_URL=https://votre-domaine.com     # URL publique du Droplet
FRONTEND_URL=https://votre-domaine.com # URL frontend (si différente de APP_URL)
APP_BIND=0.0.0.0
APP_PORT=80                           # Port exposé (80 si derrière Nginx/Certbot)

# ── Session / Sanctum / CORS (anti CSRF token mismatch) ──
# Optionnel: laissé vide, l'entrypoint génère des valeurs sûres depuis APP_URL/FRONTEND_URL.
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=
SESSION_SAME_SITE=lax
SANCTUM_STATEFUL_DOMAINS=
# Hôtes à ajouter sans écraser la liste dérivée (ex. accès http://IP avant DNS)
SANCTUM_EXTRA_STATEFUL_DOMAINS=
CORS_ALLOWED_ORIGINS=

# ── Base de données ──
DB_DATABASE=bfatlm
DB_USERNAME=bfatlm
DB_PASSWORD=                          # Mot de passe PostgreSQL fort
DB_SSLMODE=disable

# ── Redis ──
REDIS_PASSWORD=

# ── WebSocket (Reverb) ──
REVERB_APP_ID=tlm-bfa-prod
REVERB_APP_KEY=                       # Auto-généré si vide
REVERB_APP_SECRET=                    # Auto-généré si vide
REVERB_HOST=votre-domaine.com         # Domaine public (sans protocole)
REVERB_PORT=443
REVERB_SCHEME=https
ENABLE_REVERB=true
ENABLE_QUEUE=true

# ── LiveKit (visioconférence) ──
LIVEKIT_WS_URL=wss://votre-projet.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=120

# ── Stockage (DigitalOcean Spaces ou local) ──
FILESYSTEM_DISK=local                 # Changer en "s3" pour Spaces
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=fra1               # Région du Space
AWS_BUCKET=                           # Nom du Space
AWS_ENDPOINT=https://fra1.digitaloceanspaces.com

# ── Mail ──
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@bfa-tlm.bf

# ── Seeding (première installation uniquement) ──
RUN_SEED=false                        # Activer uniquement pour initialisation
SEED_DEMO_DATA=false                  # true pour charger les données de démo
# Mot de passe du premier admin (min. 12 caractères en prod). Sinon mot de passe aléatoire dans les logs.
INITIAL_ADMIN_EMAIL=admin@bfa-tlm.bf
INITIAL_ADMIN_PASSWORD=

# Comptes métier (un par rôle : gestionnaire, médecin, spécialiste, infirmier, patient démo)
# Activer uniquement à l'initialisation ; même mot de passe pour tous ces comptes (à changer après).
SEED_ROLE_ACCOUNTS=false
INITIAL_ROLE_ACCOUNTS_PASSWORD=
