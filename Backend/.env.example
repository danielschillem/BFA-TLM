APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# Origines CORS separees par virgules, sans slash final.
# Les wildcards simples sont supportes, ex: https://*.hostingersite.com
# Laissez vide si vous voulez deriver automatiquement depuis FRONTEND_URL et APP_URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Expressions regulieres Laravel CORS (optionnel)
CORS_ALLOWED_ORIGIN_PATTERNS=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── dcm4chee PACS (DICOM) ─────────────────────────────────────────────────────
DCM4CHEE_BASE_URL=http://localhost:8080/dcm4chee-arc
DCM4CHEE_AET=DCM4CHEE
DCM4CHEE_WADO_RS=/aets/DCM4CHEE/rs
DCM4CHEE_STOW_RS=/aets/DCM4CHEE/rs
DCM4CHEE_QIDO_RS=/aets/DCM4CHEE/rs
DCM4CHEE_TIMEOUT=30
DCM4CHEE_AUTH_ENABLED=false
DCM4CHEE_USERNAME=
DCM4CHEE_PASSWORD=
# OHIF Viewer (optionnel)
OHIF_VIEWER_URL=

# ── OMS ICD-11 API (Classification Internationale des Maladies) ────────────────
ICD11_TOKEN_ENDPOINT=https://icdaccessmanagement.who.int/connect/token
ICD11_API_BASE_URL=https://id.who.int
ICD11_CLIENT_ID=
ICD11_CLIENT_SECRET=
ICD11_API_VERSION=v2
ICD11_RELEASE_ID=2024-01
ICD11_LANGUAGE=fr
ICD11_LINEARIZATION=mms
ICD11_TIMEOUT=15
