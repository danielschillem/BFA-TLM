# Utilise le proxy Vite en local et le meme hote en production.
VITE_API_URL=/api/v1
VITE_APP_NAME="LiptakoCare Live"

# JaaS 8x8.vc — Définir VITE_JAAS_APP_ID active le mode JaaS (JWT obligatoire côté backend).
# Sans cette variable, le frontend utilise meet.jit.si (gratuit, sans JWT).
# VITE_JAAS_APP_ID=vpaas-magic-cookie-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Laravel Reverb WebSocket
VITE_REVERB_APP_KEY=tlm-bfa-reverb-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Mode mock : active les données simulées pour le développement frontend
# Mettre à "true" pour développer sans backend
VITE_USE_MOCKS=false
