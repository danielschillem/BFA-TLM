{
  "name": "@alternatives-it/tlm-bfa-frontend",
  "private": true,
  "version": "3.0.0",
  "description": "LiptakoCare — Plateforme de Télémédecine du Burkina Faso (Frontend)",
  "license": "UNLICENSED",
  "author": "Alternatives-IT (AIT) — Financé par ANABASE INC",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-runtime-config.mjs development && vite",
    "build": "node scripts/generate-runtime-config.mjs production && vite build --mode production",
    "build:hostinger": "node scripts/generate-runtime-config.mjs production.hostinger && vite build --mode production.hostinger",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios",
    "cap:build": "npm run build && npx cap sync",
    "cap:assets": "npx @capacitor/assets generate --iconBackgroundColor \"#1e40af\" --splashBackgroundColor \"#1e40af\" --android --ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
